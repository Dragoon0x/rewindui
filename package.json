{
  "name": "userewindui",
  "version": "1.0.0",
  "description": "Visual changelog for AI agent edits. Tracks every DOM mutation. Visual overlays on changed elements, DOM snapshots, smart commit labels, timeline scrubber, before/after diffs, accept/reject with undo, annotations, session persistence, impact scoring. Git blame for the visual layer.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify --external react --external react-dom",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external react --external react-dom",
    "test": "node test/run.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "rewind", "visual-diff", "dom-observer", "changelog", "ai-agent",
    "mutation", "before-after", "timeline", "undo", "cursor",
    "claude-code", "copilot", "devtools", "react", "overlays", "snapshots"
  ],
  "author": "0xDragoon",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/dragoon0x/rewindui" },
  "homepage": "https://dragoon0x.github.io/rewindui/",
  "sideEffects": false
}
